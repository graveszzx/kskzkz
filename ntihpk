-- ── Envia mensagem pro webhook ──────────────────────────────────────────────
local function sendWebhook(title, description, color)
	local username = LocalPlayer and LocalPlayer.Name or "Unknown"
	local userId   = LocalPlayer and tostring(LocalPlayer.UserId) or "?"

	local payload = HttpService:JSONEncode({
		embeds = {{
			title       = title,
			description = description .. "\n\n**User:** `" .. username .. "`\n**UserId:** `" .. userId .. "`\n**Game:** `" .. tostring(game.PlaceId) .. "`",
			color       = color or 16711680,
		}}
	})

	pcall(function()
		-- usa a HttpGet real (antes de qualquer hook) pra não ser bloqueado
		local http = typeof(request) == "function" and request or (typeof(syn) == "table" and syn.request) or nil
		if http then
			http({
				Url    = WEBHOOK,
				Method = "POST",
				Headers = { ["Content-Type"] = "application/json" },
				Body   = payload,
			})
		end
	end)
end

