-- ── Verifica se a função está hookada ──────────────────────────────────────
local function isHooked(fn)
	if islclosure and iscclosure then
		return islclosure(fn)
	end
	return false
end

-- ── Checagem principal (chamada no início e em loop) ───────────────────────
local hookDetected = false
local function antiHookCheck()
	if hookDetected then return end

	if isHooked(game.HttpGet) or isHooked(game.HttpGetAsync) then
		hookDetected = true

		-- 1. Notifica via webhook
		sendWebhook(
			"⚠️ Hook Detectado!",
			"Alguém tentou hookar os URLs do script.",
			16711680  -- vermelho
		)

		-- 2. Mostra tela de kick
		showKickScreen()

		-- 3. Destrói qualquer gui do hub
		pcall(function()
			for _, v in ipairs(game.CoreGui:GetChildren()) do
				if v.Name == "MitHubKeyGui" or v.Name == "MitHub_V3" then
					v:Destroy()
				end
			end
		end)

		error("", 0)
	end
end

-- ── Loop contínuo anti-hook (sempre ativo) ─────────────────────────────────
task.spawn(function()
	while true do
		task.wait(1)
		pcall(antiHookCheck)
		if hookDetected then break end
	end
end)

-- ── XOR Encode / Decode ────────────────────────────────────────────────────
local KEY = {72, 13, 99, 47, 201, 88, 34, 156}

local function xorEncode(str)
	local out = {}
	for i = 1, #str do
		out[i] = string.char(bit32.bxor(string.byte(str, i), KEY[((i-1) % #KEY) + 1]))
	end
	return table.concat(out)
end

local function xorDecode(str)
	return xorEncode(str)
end

local function secureGet(encodedUrl)
	antiHookCheck()
	return game:HttpGet(xorDecode(encodedUrl))
end

