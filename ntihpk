-- ── Carrega os scripts e loga via webhook ──────────────────────────────────
local function loadScripts()
	statusLabel.Text      = "Carregando scripts..."
	statusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)

	-- Notifica que o usuário carregou o script
	sendWebhook(
		"✅ Script Carregado",
		"Um usuário carregou o MitHub com sucesso.",
		65280  -- verde
	)

	local success1, err1 = pcall(function()
		loadstring(secureGet(RAW_SCRIPT1_URL))()
	end)

	local success2, err2 = pcall(function()
		loadstring(secureGet(RAW_SCRIPT2_URL))()
	end)

	if success1 and success2 then
		keyGui:Destroy()
	else
		statusLabel.Text      = "Erro ao carregar scripts!"
		statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		if not success1 then warn("Erro Script 1: " .. tostring(err1)) end
		if not success2 then warn("Erro Script 2: " .. tostring(err2)) end
	end
end

confirmBtn.MouseButton1Click:Connect(function()
	local input = box.Text:match("^%s*(.-)%s*$")
	if input == validKey then
		statusLabel.Text      = "Key válida! Carregando..."
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
		task.wait(0.5)
		loadScripts()
	else
		statusLabel.Text = "Key inválida. Tente novamente."
		box.Text         = ""
	end
end)

UserInputService.InputBegan:Connect(function(input, gp)
	if not gp and input.KeyCode == Enum.KeyCode.Return then
		confirmBtn.MouseButton1Click:Fire()
	end
end)
